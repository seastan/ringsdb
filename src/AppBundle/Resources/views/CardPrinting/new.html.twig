{% extends 'AppBundle:Admin:base.html.twig' %}

{% block content %}
<h1>New Card Printing</h1>

<div class="well well-sm" style="margin-bottom:1em">
    <strong>Step 1 — filter cards by pack (optional):</strong>
    <form method="GET" action="{{ path('admin_card_printing_new') }}" class="form-inline" style="margin-top:0.4em">
        <select name="filter_pack" class="form-control" style="width:auto">
            <option value="">— show all cards —</option>
            {% for pack in packs %}
                <option value="{{ pack.id }}"{% if filter_pack == pack.id %} selected="selected"{% endif %}>{{ pack.name }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="btn btn-default btn-sm">Apply filter</button>
        {% if filter_pack %}
            <a href="{{ path('admin_card_printing_new') }}" class="btn btn-link btn-sm">Clear</a>
        {% endif %}
    </form>
</div>

<form action="{{ path('admin_card_printing_create') }}{% if filter_pack %}?filter_pack={{ filter_pack }}{% endif %}" method="post" {{ form_enctype(form) }}>
    {{ form_widget(form) }}
    <button type="submit" class="btn btn-success">Create</button>
</form>

<a href="{{ path('admin_card_printing') }}" class="btn btn-default" style="margin-top:0.5em">Back to the list</a>
{% endblock %}
