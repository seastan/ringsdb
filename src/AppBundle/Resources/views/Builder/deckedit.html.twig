{% extends 'AppBundle::layout.html.twig' %}
{% import "AppBundle::macros.html.twig" as macros %}

{% block javascripts %}
    {% javascripts '@AppBundle/Resources/public/js/ui.deckedit.js' %}
    <script src="{{ asset_url }}"></script>

    {% endjavascripts %}

    <script type="text/javascript">
        app.deck && app.deck.init({{ deck | json_encode | raw }});
        app.deck_history && app.deck_history.init({{ deck.history | json_encode | raw }});
    </script>
{% endblock %}

{% block body %}
    <div class="main white container">
        {% if deck.isUnsaved %}
            <div class="alert alert-danger" role="alert" id="deck-unsaved-alert"><span class="fa fa-exclamation-triangle"></span> This deck has unsaved changes. Please save the deck or cancel the changes before making further edits.</div>
        {% endif %}

        <div id="multi-deck-tabs"></div>

        <div class="row">
            <!-- Left-side Column -->
            <div class="col-md-6">
                <div id="deck-content" class="deck-loading">
                    <i class="fa fa-spinner fa-spin fa-5x"></i>
                </div>
                <div id="sideboard-content"></div>

                {% include 'AppBundle:Builder:table-suggestions.html.twig' %}

                <form method="POST" action="{{ path('deck_save') }}" id="save_form" role="form" style="margin-bottom: 1em; margin-top: 2em;">
                    <input type="hidden" id="deck-save-id" name="id" value="{{ deck.id }}">
                    <input type="hidden" id="deck-save-as-copy" name="copy" value="0">
                    <input type="hidden" id="deck-cancel-edits" name="cancel_edits" value="0">
                    <input type="hidden" name="content">
                    <input type="hidden" name="description">
                    <input type="hidden" name="tags">
                    <div class="form-group">
                        <label for="name">Deck Name</label>
                        <input type="text" class="form-control decklist-name" name="name" value="{{ deck.name }}">
                    </div>
                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="submit" id="btn-cancel-edits" class="btn btn-link">Cancel edits</button>
                </form>

            </div>
            <!-- Left-side Column -->

            <!-- Right-side Column -->
            <div class="col-md-6">
                <div role="tabpanel">
                    <ul class="nav nav-tabs" role="tablist">
                        <li role="presentation" class="active"><a href="#tab-pane-build" aria-controls="tab-pane-build" role="tab" data-toggle="tab"><span class="fa fa-puzzle-piece"></span> Build</a></li>
                        <li role="presentation"><a href="#tab-pane-infos" aria-controls="tab-pane-infos" role="tab" data-toggle="tab"><span class="fa fa-pencil-square-o"></span> Notes</a></li>
                        <li role="presentation"><a href="#tab-pane-draw" aria-controls="tab-pane-draw" role="tab" data-toggle="tab"><span class="fa fa-repeat"></span> <span class="hidden-xs">Test</span></a></li>
                        <li role="presentation"><a href="#tab-pane-play" aria-controls="tab-pane-play" role="tab" data-toggle="tab"><span class="fa fa-play"></span> <span class="hidden-xs">Play</span></a></li>
                        <li role="presentation"><a href="#tab-pane-charts" aria-controls="tab-pane-charts" role="tab" data-toggle="tab"><span class="fa fa-bar-chart"></span> <span class="hidden-xs">Charts</span></a></li>
                        <li role="presentation"><a href="#tab-pane-history" aria-controls="tab-pane-history" role="tab" data-toggle="tab" id="tab-header-history"><span class="fa fa-history"></span> <span class="hidden-xs">History</span></a></li>
                    </ul>
                    <div class="tab-content">
                        <div role="tabpanel" class="tab-pane active" id="tab-pane-build">
                            {% include 'AppBundle:Builder:tab-pane-build.html.twig' %}
                        </div>
                        <div role="tabpanel" class="tab-pane" id="tab-pane-draw">
                            {% include 'AppBundle:Builder:tab-pane-draw.html.twig' %}
                        </div>
                        <div role="tabpanel" class="tab-pane" id="tab-pane-play">
                            {% include 'AppBundle:Builder:tab-pane-play.html.twig' %}
                        </div>
                        <div role="tabpanel" class="tab-pane" id="tab-pane-charts">
                            {% include 'AppBundle:Builder:tab-pane-charts.html.twig' %}
                        </div>
                        <div role="tabpanel" class="tab-pane" id="tab-pane-infos">
                            {% include 'AppBundle:Builder:tab-pane-infos.html.twig' %}
                        </div>
                        <div role="tabpanel" class="tab-pane" id="tab-pane-history">
                            {% include 'AppBundle:Builder:tab-pane-history.html.twig' %}
                        </div>
                    </div>
                </div>
            </div>
            <!-- Right-side Column -->

        </div>

        <div class="row">
            <p class="text-center text-muted small">
                <a href="#" class="data-update">Refresh all application data</a>
            </p>
        </div>
    </div>

    {% include 'AppBundle:Modale:odds.html.twig' %}

    <div class="modal fade" id="multiDeckCloseModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Close deck</h4>
                </div>
                <div class="modal-body">
                    <p id="multiDeckCloseMessage"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-default js-close-discard">Close without saving</button>
                    <button type="button" class="btn btn-success js-close-save">Save &amp; Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="multiDeckLoadModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h3 class="modal-title">Add a Deck to Builder</h3>
                </div>
                <div class="modal-body" style="padding: 0">
                    <table class="table table-expanded list-decks" style="margin-bottom: 0">
                        <tbody id="multiDeckLoadList"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
